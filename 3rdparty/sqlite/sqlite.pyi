SQLITE_DONE: int = 101
SQLITE_ROW: int = 100
SQLITE_MISUSE: int = 21
SQLITE_OK: int = 0

class Stmt():
  def step(self) -> int: ...
  def bind(self, fmt: str, value: list | tuple) -> int: ...
  def get_columns(self, fmt: str) -> tuple: ...

class Database():
  def close(self) -> None: ...
  def prepare(self, sql: str) -> Stmt: ...
